{
  "name": "lutris-gamepad-ui",
  "private": true,
  "version": "0.2.0",
  "main": "electron.cjs",
  "type": "module",
  "description": "A simple, TV-friendly, gamepad-navigable frontend for the Lutris game launcher on Linux.",
  "author": {
    "name": "Andrew-LD",
    "email": "andrewld@protonmail.com"
  },
  "license": "GPL-3.0-only",
  "homepage": "https://github.com/andrew-ld/lutris-gamepad-ui/",
  "scripts": {
    "dev": "vite",
    "start": "LUTRIS_GAMEPAD_UI_IS_DEV=1 concurrently \"npm run dev\" \"npm run electron:dev\"",
    "start:prod": "npm run build:vite && npx electron electron.cjs",
    "start:prod-wayland": "npm run build:vite && npx electron electron.cjs --ozone-platform=wayland",
    "start:prod-steamdeck": "npm run build:vite && gamescope -W 1280 -w 1280 -H 800 -h 800 -- npx electron electron.cjs",
    "build:vite": "vite build",
    "electron:build": "electron-builder --config electron-builder.config.cjs",
    "build": "npm run build:vite && npm run electron:build",
    "electron:dev": "wait-on http://localhost:5173 && electron .",
    "lint": "eslint .",
    "prettier": "prettier -w ."
  },
  "dependencies": {
    "@futpib/paclient": "github:andrew-ld/paclient#450fc5046e2bb6b3ce7920211ec89bc3748d0463",
    "@homebridge/dbus-native": "github:andrew-ld/dbus-native#b1e7adc7daf54a3c1d23912cb020832085322109",
    "koffi": "^2.16.1",
    "modern-tar": "^0.7.6"
  },
  "devDependencies": {
    "zustand": "^5.0.13",
    "@babel/parser": "^7.29.3",
    "@babel/plugin-syntax-jsx": "^7.28.6",
    "@babel/traverse": "^7.29.0",
    "@electron/fuses": "^2.1.1",
    "@eslint-react/eslint-plugin": "^5.7.0",
    "@eslint/css": "^1.2.0",
    "@eslint/js": "^10.0.1",
    "@preact/preset-vite": "^2.10.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "postcss": "^8.5.13",
    "preact": "^10.29.1",
    "prettier": "^3.8.3",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  }
}
